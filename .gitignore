# Generated books, circuit derivatives, and reports
/build/**
!/build/.gitkeep

# Legacy output location; safe to remove locally
/curriculum/build/**

# Local caches
__pycache__/
*.py[cod]
.pytest_cache/
.quarto/

# Restricted stores are separate; public markers remain empty
/curriculum-private/current-assessments/**
!/curriculum-private/current-assessments/.gitkeep
/curriculum-private/restricted-solutions/**
!/curriculum-private/restricted-solutions/.gitkeep
/curriculum-private/protected-student-partner-data/**
!/curriculum-private/protected-student-partner-data/.gitkeep
