{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emm.edu/schemas/backlog.schema.json",
  "title": "Generated canonical child backlog",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "generated_from",
    "items"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string"
    },
    "generated_from": {
      "type": "array"
    },
    "generated_at": {
      "type": "string"
    },
    "generation_rule": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "manifest_id",
          "manifest_kind",
          "resource",
          "applicability",
          "edition_children",
          "approval_facets",
          "apparatus_paths",
          "pilots",
          "defect_disposition",
          "evidence_links",
          "approver",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "manifest_id": {
            "type": "string",
            "minLength": 1
          },
          "manifest_kind": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "resource": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "applicability": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "edition_children": {
            "type": "array"
          },
          "approval_facets": {
            "type": "array"
          },
          "apparatus_paths": {
            "type": [
              "object",
              "array"
            ]
          },
          "pilots": {
            "type": "array"
          },
          "defect_disposition": {
            "type": [
              "object",
              "array"
            ]
          },
          "evidence_links": {
            "type": "array"
          },
          "approver": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "localized": {
      "type": "object",
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "brief",
        "draft",
        "review",
        "technical-review",
        "language-review",
        "pilot",
        "pilot-ready",
        "stable",
        "released",
        "retired",
        "approved",
        "approved-baseline",
        "mapping-in-progress",
        "qualification-pending",
        "quote-required",
        "not-started",
        "pending"
      ]
    }
  }
}
