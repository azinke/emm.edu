{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emm.edu/schemas/contribution.schema.json",
  "title": "V0-V4 and contribution/provenance dossier",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "status",
    "levels",
    "contribution_records"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string"
    },
    "levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "capability",
          "required_evidence",
          "claim_limit"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": [
              "object",
              "string"
            ]
          },
          "capability": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "required_evidence": {
            "type": "array"
          },
          "claim_limit": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "contribution_records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "project_id",
          "target_level",
          "contributions",
          "imported_dependencies",
          "make_buy_rationale",
          "capability_gaps",
          "next_local_step",
          "permitted_claim",
          "legal_review",
          "reviewer",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_id": {
            "type": "string",
            "minLength": 1
          },
          "target_level": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "contributions": {
            "type": "array"
          },
          "imported_dependencies": {
            "type": "array"
          },
          "make_buy_rationale": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "capability_gaps": {
            "type": "array"
          },
          "next_local_step": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "permitted_claim": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "legal_review": {
            "type": [
              "object",
              "array"
            ]
          },
          "reviewer": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "localized": {
      "type": "object",
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "brief",
        "draft",
        "review",
        "technical-review",
        "language-review",
        "pilot",
        "pilot-ready",
        "stable",
        "released",
        "retired",
        "approved",
        "approved-baseline",
        "mapping-in-progress",
        "qualification-pending",
        "quote-required",
        "not-started",
        "pending"
      ]
    }
  }
}
