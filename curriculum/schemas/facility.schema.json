{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emm.edu/schemas/facility.schema.json",
  "title": "Facility capability records",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "status",
    "facilities"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string"
    },
    "facilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "profile_id",
          "name",
          "location",
          "capabilities",
          "capacity_learners",
          "safety_authorizations",
          "equipment_ids",
          "accessibility_routes",
          "partner_routes",
          "evidence_ids",
          "review_date",
          "review_due",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "profile_id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": [
              "object",
              "string"
            ]
          },
          "location": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "capabilities": {
            "type": "array"
          },
          "capacity_learners": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "safety_authorizations": {
            "type": "array"
          },
          "equipment_ids": {
            "type": "array"
          },
          "accessibility_routes": {
            "type": "array"
          },
          "partner_routes": {
            "type": "array"
          },
          "evidence_ids": {
            "type": "array"
          },
          "review_date": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "review_due": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "localized": {
      "type": "object",
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "brief",
        "draft",
        "review",
        "technical-review",
        "language-review",
        "pilot",
        "pilot-ready",
        "stable",
        "released",
        "retired",
        "approved",
        "approved-baseline",
        "mapping-in-progress",
        "qualification-pending",
        "quote-required",
        "not-started",
        "pending"
      ]
    }
  }
}
