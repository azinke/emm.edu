{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emm.edu/schemas/outcome.schema.json",
  "title": "Program and course outcomes",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "status",
    "progression_levels",
    "peos",
    "plos",
    "course_outcomes",
    "graduation_rule"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string"
    },
    "progression_levels": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "level",
          "name",
          "definition",
          "typical_evidence"
        ],
        "properties": {
          "level": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "name": {
            "type": [
              "object",
              "string"
            ]
          },
          "definition": {
            "type": [
              "object",
              "string"
            ]
          },
          "typical_evidence": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "peos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "definition",
          "time_horizon_years",
          "maps_to",
          "evidence_sources",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": [
              "object",
              "string"
            ]
          },
          "definition": {
            "type": [
              "object",
              "string"
            ]
          },
          "time_horizon_years": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "maps_to": {
            "type": "array"
          },
          "evidence_sources": {
            "type": "array"
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    },
    "plos": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "definition",
          "graduation_evidence",
          "minimum_level",
          "graduation_confirmation",
          "mapped_peos",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "definition": {
            "type": [
              "object",
              "string"
            ]
          },
          "graduation_evidence": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "minimum_level": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "graduation_confirmation": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "mapped_peos": {
            "type": "array"
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    },
    "course_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "course_id",
          "semester",
          "definition",
          "progression_level",
          "maps_to",
          "evidence",
          "assessment_points",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "course_id": {
            "type": "string",
            "minLength": 1
          },
          "semester": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "definition": {
            "type": [
              "object",
              "string"
            ]
          },
          "progression_level": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          },
          "maps_to": {
            "type": "array"
          },
          "evidence": {
            "type": "array"
          },
          "assessment_points": {
            "type": "array"
          },
          "status": {
            "$ref": "#/$defs/status"
          }
        }
      }
    },
    "graduation_rule": {
      "type": "object"
    },
    "source": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "localized": {
      "type": "object",
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "brief",
        "draft",
        "review",
        "technical-review",
        "language-review",
        "pilot",
        "pilot-ready",
        "stable",
        "released",
        "retired",
        "approved",
        "approved-baseline",
        "mapping-in-progress",
        "qualification-pending",
        "quote-required",
        "not-started",
        "pending"
      ]
    }
  }
}
