{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emm.edu/schemas/termbase.schema.json",
  "title": "Controlled bilingual terminology",
  "type": "object",
  "required": [
    "schema_version",
    "version",
    "status",
    "terms"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "status": {
      "type": "string"
    },
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "concept_id",
          "domain",
          "definition",
          "terms",
          "avoided_terms",
          "acronym_policy",
          "example",
          "usage_note",
          "reviewer",
          "status",
          "source_section"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "concept_id": {
            "type": "string",
            "minLength": 1
          },
          "domain": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "definition": {
            "type": [
              "object",
              "string"
            ]
          },
          "terms": {
            "type": [
              "object",
              "array"
            ]
          },
          "avoided_terms": {
            "type": [
              "object",
              "array"
            ]
          },
          "acronym_policy": {
            "type": [
              "object",
              "array"
            ]
          },
          "example": {
            "type": [
              "object",
              "array"
            ]
          },
          "usage_note": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "reviewer": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          },
          "status": {
            "$ref": "#/$defs/status"
          },
          "source_section": {
            "type": [
              "string",
              "object",
              "array",
              "number",
              "boolean",
              "null"
            ]
          }
        }
      }
    },
    "source": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9]*(?:-[A-Z0-9]+)+$"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "localized": {
      "type": "object",
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "brief",
        "draft",
        "review",
        "technical-review",
        "language-review",
        "pilot",
        "pilot-ready",
        "stable",
        "released",
        "retired",
        "approved",
        "approved-baseline",
        "mapping-in-progress",
        "qualification-pending",
        "quote-required",
        "not-started",
        "pending"
      ]
    }
  }
}
