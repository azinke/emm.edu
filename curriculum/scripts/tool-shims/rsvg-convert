#!/usr/bin/env python3
"""Adapt Pandoc's rsvg-convert call to an installed Inkscape executable."""

from __future__ import annotations

import argparse
import shutil
import subprocess
import sys


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("-f", "--format", default="pdf")
    parser.add_argument("-a", "--keep-aspect-ratio", action="store_true")
    parser.add_argument("--dpi-x")
    parser.add_argument("--dpi-y")
    parser.add_argument("-o", "--output", required=True)
    parser.add_argument("source")
    args = parser.parse_args()
    if args.format != "pdf":
        print(f"ERROR Inkscape fallback does not support {args.format!r} output", file=sys.stderr)
        return 2
    inkscape = shutil.which("inkscape")
    if not inkscape:
        print("ERROR SVG rendering requires rsvg-convert or inkscape", file=sys.stderr)
        return 2
    completed = subprocess.run(
        [
            inkscape,
            args.source,
            "--export-type=pdf",
            f"--export-filename={args.output}",
        ],
        check=False,
    )
    return completed.returncode


if __name__ == "__main__":
    sys.exit(main())
